# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# --- Secrets / config ---
.env
.env.local
*.key

# --- Lattice render artifacts (regenerated; never commit) ---
out/
media/            # Manim default output dir
renders/
cache/            # content-hash render + TTS cache
*.mp4
*.mkv
*.wav
*.mp3
*.srt
# keep tiny checked-in sample fixtures if any are added under tests/fixtures/
!tests/fixtures/**

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- local reference clones / scratch (NOT Lattice code) ---
# (gitignore has no inline comments — keep patterns on their own line)
# external manim-from-prompt repo, kept locally for reference
manimator/
# scratch probe of Manim's bbox API
/test_manim_api.py
# accidental output-redirect artifact
*scratchpadtest_manim_api.py
