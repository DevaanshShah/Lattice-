# Copy to .env and fill in. All vars are prefixed LATTICE_.
# Generator and critic are DIFFERENT, swappable models (strong coder writes; cheap vision model checks).
# Not called in M0 — wired for M1+.

LATTICE_LLM_BASE_URL=https://openrouter.ai/api/v1
LATTICE_LLM_API_KEY=
LATTICE_LLM_MODEL=anthropic/claude-sonnet-4.5
LATTICE_CRITIC_MODEL=openai/gpt-4o-mini

# Render sandbox (Q5 = containerized). Keep network OFF (the sandbox invariant).
LATTICE_RENDER_NETWORK=false

# TTS (Q3, used from M4)
LATTICE_TTS_ENGINE=gtts
